async function deletePromo(id) {
    hapticLight();
    window.Telegram.WebApp.showPopup({
        message: 'Удалить промокод?',
        buttons: [
            { id: 'ok', type: 'destructive', text: 'Удалить' },
            { id: 'cancel', type: 'cancel' }
        ]
    }, async (buttonId) => {
        if (buttonId !== 'ok') return;
        try {
            await fetch(`${API}/api/promo-codes/${id}/delete`, { method: 'DELETE', headers: { 'Authorization': `Bearer ${getAdminToken()}` } });
            loadPromosList();
        } catch(e) { alert('Ошибка'); }
    });
}

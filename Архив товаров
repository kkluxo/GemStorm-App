async function loadPromosList() {
    const container = document.getElementById('promosList');
    if (!container) return;
    try {
        const r = await fetch(`${API}/api/promo-codes`, {
            headers: { 'Authorization': `Bearer ${getAdminToken()}` }
        });
        const list = await r.json();
        if (!list.length) { container.innerHTML = '<div class="empty-state"><div class="empty-title">Промокодов нет</div></div>'; return; }
        
        container.innerHTML = list.map(p => {
            const now = new Date();
            const isExpired = p.expires_at && new Date(p.expires_at) < now;
            const isLimitReached = p.max_uses !== null && p.used_count >= p.max_uses;
            const isActive = p.active && !isExpired && !isLimitReached;
            
            let expiresStr = '∞';
            if (p.expires_at) {
                const d = new Date(p.expires_at);
                const hh = String(d.getHours()).padStart(2,'0');
                const mm = String(d.getMinutes()).padStart(2,'0');
                const dd = String(d.getDate()).padStart(2,'0');
                const mo = String(d.getMonth()+1).padStart(2,'0');
                expiresStr = `${hh}:${mm} ${dd}.${mo}`;
            }
            
            const uses = p.max_uses ? `${p.used_count}/${p.max_uses}` : `${p.used_count}/∞`;
            const forUser = p.user_id ? `Для: ${p.user_id}` : 'Для всех';
            
            return `<div class="order-wrapper" style="margin-bottom:14px;">
                <div class="order-main-card" style="position:relative;">
                    <div class="order-header">
                        <span class="order-id">${p.code}</span>
                        <span class="order-card-status ${isActive ? 'status-completed-text status-completed-bg' : 'status-cancelled-text status-cancelled-bg'}">${isActive ? 'Активен' : 'Не активен'}</span>
                    </div>
                    <div class="order-date">${forUser} · Тип: ${p.type === 'first_order' ? 'первый заказ' : 'все'}</div>
                    <div class="order-total">−${p.discount}%</div>
                    <button onclick="deletePromo(${p.id})" style="position:absolute;bottom:12px;right:12px;background:rgba(239,68,68,0.12);border:none;border-radius:50%;width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;">
                        <img src="https://storage.botpapa.me/files/19b700d0-4a0d-11f1-bef9-f1ec7a2c6e45.png" style="width:18px;height:18px;">
                    </button>
                </div>
                <div class="order-items-card">
                    <div class="order-item-row"><span class="order-item-name">Использований</span><span class="order-item-price">${uses}</span></div>
                    <div class="order-item-row"><span class="order-item-name">Срок действия</span><span class="order-item-price">${expiresStr}</span></div>
                </div>
            </div>`;
        }).join('');
    } catch(e) {
        container.innerHTML = '<div class="empty-state">Ошибка загрузки</div>';
    }
}
```


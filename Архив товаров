async function renderCreatePromoPage() {
    const container = document.getElementById('createPromoContent');
    const headerContainer = document.getElementById('createPromoHeader');
    if (headerContainer) headerContainer.innerHTML = renderPageHeader('https://storage.botpapa.me/files/8324fec0-5933-11f1-bef9-f1ec7a2c6e45.png', 'Создать промокод');
    if (!container) return;

    container.innerHTML = `
        <div class="settings-card">
            <div style="display:flex;flex-direction:column;gap:10px;">
                <input id="promoCode" placeholder="Введите промокод" style="background:#303032;border-radius:34px;padding:14px 16px;color:white;font-size:17px;border:none;outline:none;width:100%;">
                <input id="promoDiscount" type="number" placeholder="Процент скидки" min="1" max="100" style="background:#303032;border-radius:34px;padding:14px 16px;color:white;font-size:17px;border:none;outline:none;width:100%;">
                <select id="promoType" style="background:#303032;border-radius:34px;padding:14px 16px;color:white;font-size:17px;border:none;outline:none;width:100%;appearance:none;">
                    <option value="all">Все заказы</option>
                    <option value="first_order">Первый заказ</option>
                </select>
                <input id="promoUserId" placeholder="ID пользователя (необязательно)" style="background:#303032;border-radius:34px;padding:14px 16px;color:white;font-size:17px;border:none;outline:none;width:100%;">
                <input id="promoExpires" placeholder="Срок действия: 14:08 21.06 (МСК)" style="background:#303032;border-radius:34px;padding:14px 16px;color:white;font-size:17px;border:none;outline:none;width:100%;">
                <input id="promoMaxUses" type="number" placeholder="Количество активаций (необязательно)" min="1" style="background:#303032;border-radius:34px;padding:14px 16px;color:white;font-size:17px;border:none;outline:none;width:100%;">
            </div>
        </div>`;

    const oldFixed = document.getElementById('adminFixedBar');
    if (oldFixed) oldFixed.remove();
    const fixedBar = document.createElement('div');
    fixedBar.id = 'adminFixedBar';
    fixedBar.className = 'fixed-bottom-bar';
    fixedBar.innerHTML = `<div class="action-card"><div class="action-buttons-row"><button class="update-status-btn" id="createPromoSubmitBtn">Создать промокод</button></div></div>`;
    document.body.appendChild(fixedBar);

    setTimeout(() => {
        document.getElementById('createPromoSubmitBtn')?.addEventListener('click', async () => {
            hapticMedium();
            const code = document.getElementById('promoCode')?.value.trim();
            const discount = document.getElementById('promoDiscount')?.value;
            const type = document.getElementById('promoType')?.value;
            const userId = document.getElementById('promoUserId')?.value.trim();
            const expiresRaw = document.getElementById('promoExpires')?.value.trim();
            const maxUses = document.getElementById('promoMaxUses')?.value;

            if (!code || !discount) { alert('Введите код и скидку'); return; }

            // Парсим дату формата "14:08 21.06" по МСК
            let expiresAt = null;
            if (expiresRaw) {
                try {
                    const [timePart, datePart] = expiresRaw.split(' ');
                    const [hh, mm] = timePart.split(':').map(Number);
                    const [dd, mo] = datePart.split('.').map(Number);
                    const year = new Date().getFullYear();
                    // Создаём дату по МСК (UTC+3)
                    const mskDate = new Date(Date.UTC(year, mo - 1, dd, hh - 3, mm));
                    expiresAt = mskDate.toISOString();
                } catch(e) { alert('Неверный формат срока. Используйте: 14:08 21.06'); return; }
            }

            try {
                const r = await fetch(`${API}/api/promo-codes`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getAdminToken()}` },
                    body: JSON.stringify({
                        code, discount: parseInt(discount), type,
                        userId: userId || null,
                        expiresAt,
                        maxUses: maxUses || null
                    })
                });
                const data = await r.json();
                if (r.ok) { hapticLight(); showAdminPage('promos'); }
                else alert(data.error || 'Ошибка создания');
            } catch(e) { alert('Ошибка соединения'); }
        });
    }, 0);
}
```

